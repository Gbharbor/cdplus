
; ALÍNEA (a)–INICIALIZAÇÃO


;  Endereços de I/O e memória 
LEDS                EQU     FFF8h
SENSOR              EQU     FFF9h
_POS_ATUAL          EQU     8000h
_SENTIDO_MOVIMENTO  EQU     8002h

ORIG 0000h
JMP START


; Programa principal (teste da alínea a)

START:      CALL INIT_HOMING
IDLE:       CALL DELAY
            BR IDLE


; (a) Rotina de homing

INIT_HOMING: MOV R1, 0          ; 0 = esquerda
            CALL SET_DIRECAO

HOMING:     CALL IMPULSO
            CALL LE_SENSOR
            CMP R1, 1
            BR.Z HOMING_FIM
            BR HOMING

HOMING_FIM: MOV M[_POS_ATUAL], R0   ; posição atual = 0
            RET


; Rotinas fornecidas 

LE_SENSOR:  MOV R1, M[SENSOR]
            AND R1, 1
            RET

SET_DIRECAO: MOV M[LEDS], R1
            MOV M[_SENTIDO_MOVIMENTO], R1
            RET

IMPULSO:    PUSH R1
            MOV R1, M[_SENTIDO_MOVIMENTO]
            AND R1, 1
            MOV M[LEDS], R1
            OR  R1, 2
            MOV M[LEDS], R1
            CALL DELAY
            AND R1, 1
            MOV M[LEDS], R1
            CALL DELAY
            POP R1
            RET

DELAY:      PUSH R7
            MOV R7, FFFFh
DLY:        DEC R7
            BR.NZ DLY
            POP R7
            RET